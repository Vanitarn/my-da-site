{
  "definitions": [
    {
      "title": "Image Block",
      "id": "image-block",
      "model": "image-block",
      "plugins": {
        "da": {
          "name": "image-block",
          "rows": 5,
          "columns": 1,
          "fields": [
            { "name": "image",              "selector": "div:nth-child(1)>div>picture>img[src]" },
            { "name": "imageAlt",           "selector": "div:nth-child(1)>div>picture>img[alt]" },
            { "name": "mobImage",           "selector": "div:nth-child(2)>div>picture>img[src]" },
            { "name": "mobImageAlt",        "selector": "div:nth-child(2)>div>picture>img[alt]" },
            { "name": "imageblock_label",   "selector": "div:nth-child(3)>div>:first-child" },
            { "name": "imageblock_rte",     "selector": "div:nth-child(3)>div" },
            { "name": "squareEdges",        "selector": "div:nth-child(4)>div>:first-child" },
            { "name": "fullWidth",          "selector": "div:nth-child(5)>div>:first-child" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "image-block",
      "fields": [
        {
          "component": "reference",
          "name": "image",
          "label": "Desktop Image",
          "valueType": "string",
          "multi": false,
          "required": true,
          "description": "Row 1 — Upload desktop image."
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Desktop Image Alt Text",
          "valueType": "string",
          "required": true,
          "description": "Row 1 — Field-collapse: suffix 'Alt' merges with image reference → rendered as img[alt]"
        },
        {
          "component": "reference",
          "name": "mobImage",
          "label": "Mobile Image",
          "valueType": "string",
          "multi": false,
          "description": "Row 2 — Upload mobile image. Falls back to desktop image if omitted."
        },
        {
          "component": "text",
          "name": "mobImageAlt",
          "label": "Mobile Image Alt Text",
          "valueType": "string",
          "description": "Row 2 — Field-collapse: suffix 'Alt' merges with mobImage reference → rendered as img[alt]"
        },
        {
          "component": "text",
          "name": "imageblock_label",
          "label": "Label",
          "valueType": "string",
          "description": "Row 3 — Label shown above the description (first line)"
        },
        {
          "component": "richtext",
          "name": "imageblock_rte",
          "label": "Extended Image Description",
          "valueType": "string",
          "description": "Row 3 — Description content below the label"
        },
        {
          "component": "select",
          "name": "classesdescription",
          "label": "Description Font Size",
          "valueType": "string",
          "description": "Block option (not a row) — EDS: classes_ prefix puts value in table header. DA: author types in block header parentheses e.g. 'Image Block (description-fs-20px)'. JS reads block.classList.",
          "options": [
            { "name": "100px", "value": "descriptionfs100px" },
            { "name": "60px",  "value": "descriptionfs60px" },
            { "name": "48px",  "value": "descriptionfs48px" },
            { "name": "36px",  "value": "descriptionfs36px" },
            { "name": "32px",  "value": "descriptionfs32px" },
            { "name": "28px",  "value": "descriptionfs28px" },
            { "name": "24px",  "value": "descriptionfs24px" },
            { "name": "20px",  "value": "descriptionfs20px" },
            { "name": "16px",  "value": "descriptionfs16px" },
            { "name": "14px",  "value": "descriptionfs14px" }
          ]
        },
        {
          "component": "select",
          "name": "squareEdges",
          "label": "Square Edges",
          "valueType": "string",
          "description": "Row 4 — Apply square edges on image",
          "options": [
            { "name": "Enable",  "value": "true" },
            { "name": "Disable", "value": "false" }
          ]
        },
        {
          "component": "select",
          "name": "fullWidth",
          "label": "Full Width",
          "valueType": "string",
          "description": "Row 5 — Make image full width",
          "options": [
            { "name": "Enable",  "value": "true" },
            { "name": "Disable", "value": "false" }
          ]
        }
      ]
    }
  ],
  "filters": []
}