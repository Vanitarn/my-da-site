{
  "definitions": [
    {
      "title": "Image Block",
      "id": "image-block",
      "model": "image-block",
      "plugins": {
        "da": {
          "name": "image-block",
          "rows": 5,
          "columns": 1,
          "fields": [
            { "name": "image",              "selector": "div:nth-child(1)>div>picture>img[src]" },
            { "name": "imageAlt",           "selector": "div:nth-child(1)>div>picture>img[alt]" },
            { "name": "mobImage",           "selector": "div:nth-child(2)>div>picture>img[src]" },
            { "name": "mobImageAlt",        "selector": "div:nth-child(2)>div>picture>img[alt]" },
            { "name": "imageblock_label",   "selector": "div:nth-child(3)>div>:first-child" },
            { "name": "imageblock_rte",     "selector": "div:nth-child(3)>div" },
            { "name": "squareEdges",        "selector": "div:nth-child(4)>div>:first-child" },
            { "name": "fullWidth",          "selector": "div:nth-child(5)>div>:first-child" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "image-block",
      "fields": [
        {
          "component": "reference",
          "name": "image",
          "label": "Desktop Image",
          "valueType": "string",
          "multi": false,
          "required": true,
          "description": "Row 1 — Upload desktop image."
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Desktop Image Alt Text",
          "valueType": "string",
          "required": true,
          "description": "Row 1 — Field-collapse: suffix 'Alt' merges with image reference → rendered as img[alt]"
        },
        {
          "component": "reference",
          "name": "mobImage",
          "label": "Mobile Image",
          "valueType": "string",
          "multi": false,
          "description": "Row 2 — Upload mobile image. Falls back to desktop image if omitted."
        },
        {
          "component": "text",
          "name": "mobImageAlt",
          "label": "Mobile Image Alt Text",
          "valueType": "string",
          "description": "Row 2 — Field-collapse: suffix 'Alt' merges with mobImage reference → rendered as img[alt]"
        },
        {
          "component": "text",
          "name": "imageblock_label",
          "label": "Label",
          "valueType": "string",
          "description": "Row 3 — Label shown above the description (first line)"
        },
        {
          "component": "richtext",
          "name": "imageblock_rte",
          "label": "Extended Image Description",
          "valueType": "string",
          "description": "Row 3 — Description content below the label"
        },
        {
          "component": "multiselect",
          "name": "classes",
          "label": "Style Options",
          "valueType": "string",
          "description": "Block option — each selected value is added as a CSS class on the block. Pick one font size and one background color.",
          "options": [
            { "name": "Font — 100px",          "value": "description-fs-100px" },
            { "name": "Font — 60px",           "value": "description-fs-60px" },
            { "name": "Font — 48px",           "value": "description-fs-48px" },
            { "name": "Font — 36px",           "value": "description-fs-36px" },
            { "name": "Font — 32px",           "value": "description-fs-32px" },
            { "name": "Font — 28px",           "value": "description-fs-28px" },
            { "name": "Font — 24px",           "value": "description-fs-24px" },
            { "name": "Font — 20px",           "value": "description-fs-20px" },
            { "name": "Font — 16px",           "value": "description-fs-16px" },
            { "name": "Font — 14px",           "value": "description-fs-14px" },
            { "name": "BG — None",             "value": "none" },
            { "name": "BG — Surface Neutral",  "value": "surface-neutral" },
            { "name": "BG — Surface Base",     "value": "surface-base" }
          ]
        },
        {
          "component": "boolean",
          "name": "squareEdges",
          "label": "Square Edges",
          "valueType": "boolean",
          "value": false,
          "description": "Row 4 — Check to apply square edges on image"
        },
        {
          "component": "boolean",
          "name": "fullWidth",
          "label": "Full Width",
          "valueType": "boolean",
          "value": false,
          "description": "Row 5 — Check to make the image full width"
        }
      ]
    }
  ],
  "filters": []
}