{
  "definitions": [
    {
      "title": "Image Block",
      "id": "image-block",
      "model": "image-block",
      "plugins": {
        "da": {
          "name": "image-block",
          "rows": 5,
          "columns": 1,
          "fields": [
            { "name": "image",              "selector": "div:nth-child(1)>picture>img[src]" },
            { "name": "imageAlt",           "selector": "div:nth-child(1)>picture>img[alt]" },
            { "name": "mobImage",           "selector": "div:nth-child(2)>picture>img[src]" },
            { "name": "mobImageAlt",        "selector": "div:nth-child(2)>picture>img[alt]" },
            { "name": "imageblock_label",   "selector": "div:nth-child(3)>:first-child" },
            { "name": "imageblock_rte",     "selector": "div:nth-child(3)" },
            { "name": "squareEdges",        "selector": "div:nth-child(4)>:first-child" },
            { "name": "fullWidth",          "selector": "div:nth-child(5)>:first-child" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "image-block",
      "fields": [
        {
          "component": "reference",
          "name": "image",
          "label": "Desktop Image",
          "valueType": "string",
          "multi": false,
          "required": true,
          "description": "Row 1 — Upload desktop image (alt text set on image)"
        },
        {
          "component": "reference",
          "name": "mobImage",
          "label": "Mobile Image",
          "valueType": "string",
          "multi": false,
          "description": "Row 2 — Upload mobile image (alt text set on image)"
        },
        {
          "component": "richtext",
          "name": "imageblock_rte",
          "label": "Label + Description",
          "valueType": "string",
          "description": "Row 3 — First line = label, remaining lines = description"
        },
        {
          "component": "select",
          "name": "squareEdges",
          "label": "Square Edges",
          "valueType": "string",
          "description": "Row 4 — Apply square edges on image",
          "options": [
            { "name": "Enable",  "value": "true" },
            { "name": "Disable", "value": "false" }
          ]
        },
        {
          "component": "select",
          "name": "fullWidth",
          "label": "Full Width",
          "valueType": "string",
          "description": "Row 5 — Make image full width",
          "options": [
            { "name": "Enable",  "value": "true" },
            { "name": "Disable", "value": "false" }
          ]
        }
      ]
    }
  ],
  "filters": []
}